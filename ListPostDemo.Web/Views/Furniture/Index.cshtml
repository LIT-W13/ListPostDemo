@model FurnitureViewModel

@if (!String.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>  
}

<form method="post" action="/furniture/deletemany">
    <table class="table table-hover table-bordered">
        <thead>
            <tr>
                <th class="text-center"><button class="btn btn-danger">Delete</button></th>
                <th>Name</th>
                <th>Color</th>
                <th>Price</th>
                <th>In Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.FurnitureItems)
            {
                <tr>
                    <td class="text-center">
                        <div class="form-check d-flex justify-content-center">
                            <input class="form-check-input" name="ids[]" value="@item.Id" type="checkbox" style="transform: scale(1.5);" />
                        </div>
                    </td>
                    <td>
                        @item.Name
                    </td>
                    <td>
                        @item.Color
                    </td>
                    <td>
                        @item.Price.ToString("C")
                    </td>
                    <td>
                        @item.QuantityInStock
                    </td>
                </tr>
            }
        </tbody>
    </table>
</form>
